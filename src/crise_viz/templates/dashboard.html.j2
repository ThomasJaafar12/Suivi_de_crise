<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet">
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/echarts@5.5.1/dist/echarts.min.js"></script>
  <style>
    :root {
      --bg: #f2f5f8;
      --panel: rgba(255, 255, 255, 0.88);
      --panel-strong: rgba(255, 255, 255, 0.98);
      --text: #142236;
      --muted: #62728a;
      --line: rgba(20, 34, 54, 0.12);
      --primary: #102a43;
      --accent: #1f7a8c;
      --accent-2: #ff7a59;
      --positive: #0f8b5f;
      --negative: #c84545;
      --soft-positive: #d7f4e7;
      --soft-negative: #fee4e2;
      --chip: rgba(16, 42, 67, 0.06);
      --shadow: 0 28px 90px rgba(16, 42, 67, 0.10);
      --radius-xl: 30px;
      --radius-lg: 22px;
      --radius-md: 16px;
      --radius-sm: 12px;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      min-height: 100%;
      font-family: "Manrope", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(255, 122, 89, 0.10), transparent 25%),
        radial-gradient(circle at right 10% top 12%, rgba(31, 122, 140, 0.14), transparent 24%),
        linear-gradient(180deg, #f8fbfd 0%, #eef3f7 100%);
    }

    body {
      padding: 22px;
    }

    .app-window {
      width: min(1680px, 100%);
      margin: 0 auto;
      background: rgba(248, 251, 253, 0.78);
      border: 1px solid rgba(255, 255, 255, 0.7);
      border-radius: 32px;
      box-shadow: var(--shadow);
      overflow: hidden;
      backdrop-filter: blur(22px);
    }

    .window-bar {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr) auto;
      gap: 16px;
      align-items: center;
      padding: 14px 18px;
      background: linear-gradient(180deg, rgba(255,255,255,0.86), rgba(245,248,252,0.7));
      border-bottom: 1px solid var(--line);
    }

    .window-actions {
      display: flex;
      gap: 10px;
      align-items: center;
    }

    .window-pill {
      width: 13px;
      height: 13px;
      border-radius: 999px;
      background: #d9e3ed;
      box-shadow: inset 0 0 0 1px rgba(20, 34, 54, 0.08);
    }

    .window-pill.accent { background: #ff7a59; }
    .window-pill.alt { background: #1f7a8c; }

    .browser-strip {
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 12px;
      align-items: center;
    }

    .browser-tab {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(16, 42, 67, 0.09);
      color: var(--primary);
      font-weight: 700;
      font-size: 13px;
    }

    .address-bar {
      display: flex;
      align-items: center;
      gap: 10px;
      min-width: 0;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.82);
      border: 1px solid var(--line);
      color: var(--muted);
      font-size: 13px;
    }

    .address-text {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .window-meta {
      display: flex;
      gap: 10px;
      align-items: center;
      color: var(--muted);
      font-size: 13px;
      font-weight: 600;
    }

    .app-body {
      padding: 20px;
      display: grid;
      gap: 16px;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.6fr) minmax(360px, 0.9fr);
      gap: 16px;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius-xl);
      box-shadow: 0 18px 70px rgba(16, 42, 67, 0.07);
      backdrop-filter: blur(14px);
    }

    .hero-main {
      padding: 28px;
      position: relative;
      overflow: hidden;
    }

    .hero-main::after {
      content: "";
      position: absolute;
      inset: auto -5% -18% auto;
      width: 260px;
      height: 260px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255, 122, 89, 0.22), transparent 72%);
      pointer-events: none;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(16, 42, 67, 0.08);
      color: var(--primary);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }

    h1 {
      margin: 18px 0 10px;
      font-family: "Space Grotesk", sans-serif;
      font-size: clamp(34px, 4vw, 60px);
      line-height: 0.98;
      letter-spacing: -0.05em;
      max-width: 14ch;
    }

    .hero-copy {
      max-width: 62ch;
      color: var(--muted);
      line-height: 1.7;
      font-size: 15px;
      margin: 0;
    }

    .hero-side {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      padding: 20px;
    }

    .meta-card {
      background: var(--panel-strong);
      border: 1px solid var(--line);
      border-radius: var(--radius-lg);
      padding: 16px;
      min-height: 128px;
    }

    .meta-label {
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .meta-value {
      font-size: 18px;
      font-weight: 800;
      line-height: 1.2;
    }

    .sticky-shell {
      position: sticky;
      top: 12px;
      z-index: 20;
      display: grid;
      gap: 12px;
    }

    .selector-shell {
      padding: 16px;
    }

    .selector-grid {
      display: grid;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: 12px;
    }

    .field {
      display: grid;
      gap: 8px;
      padding: 12px 14px;
      border-radius: 18px;
      background: rgba(255, 255, 255, 0.84);
      border: 1px solid var(--line);
      min-width: 0;
    }

    .field label {
      font-size: 12px;
      font-weight: 800;
      color: var(--muted);
      letter-spacing: 0.03em;
      text-transform: uppercase;
    }

    .field select,
    .field input {
      border: none;
      background: transparent;
      color: var(--text);
      font: inherit;
      outline: none;
      min-width: 0;
      width: 100%;
    }

    .field.checkbox {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .field.checkbox label {
      margin: 0;
    }

    .selector-footer {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: 14px;
    }

    .chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: var(--chip);
      color: var(--primary);
      font-size: 12px;
      font-weight: 700;
    }

    .button {
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.84);
      color: var(--text);
      border-radius: 999px;
      padding: 10px 14px;
      font: inherit;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.18s ease, background 0.18s ease;
    }

    .button:hover {
      transform: translateY(-1px);
    }

    .button.primary {
      background: var(--primary);
      color: #fff;
      border-color: transparent;
    }

    .nav-shell {
      padding: 8px;
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .nav-tab,
    .subtab,
    .toggle-pill,
    .metric-pill {
      border: none;
      background: transparent;
      color: var(--muted);
      border-radius: 999px;
      padding: 12px 16px;
      font: inherit;
      font-weight: 800;
      cursor: pointer;
      transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
    }

    .nav-tab:hover,
    .subtab:hover,
    .toggle-pill:hover,
    .metric-pill:hover {
      transform: translateY(-1px);
    }

    .nav-tab.is-active,
    .subtab.is-active,
    .toggle-pill.is-active,
    .metric-pill.is-active {
      background: var(--primary);
      color: #fff;
    }

    .content-shell {
      display: grid;
      gap: 16px;
    }

    .tab-panel {
      display: grid;
      gap: 16px;
    }

    .subtab-shell,
    .toolbar-shell {
      display: flex;
      flex-wrap: wrap;
      justify-content: space-between;
      gap: 12px;
      align-items: center;
      padding: 14px 16px;
    }

    .toolbar-left,
    .toolbar-right {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
    }

    .grid-two {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(320px, 0.8fr);
      gap: 16px;
    }

    .grid-three {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }

    .grid-four {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
    }

    .card-panel {
      padding: 18px;
      min-height: 180px;
    }

    .hero-kpis {
      padding: 18px;
    }

    .panel-title {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
      margin-bottom: 14px;
    }

    .panel-title h2,
    .panel-title h3 {
      margin: 0;
      font-size: 20px;
      font-weight: 800;
      letter-spacing: -0.03em;
    }

    .panel-title p,
    .panel-title span {
      margin: 4px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
    }

    .kpi-card {
      padding: 16px;
      border-radius: 22px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.86);
      min-height: 156px;
      display: grid;
      gap: 8px;
      align-content: start;
    }

    .kpi-card.hero {
      background: linear-gradient(180deg, rgba(16,42,67,0.96), rgba(31,122,140,0.92));
      color: #fff;
      border-color: transparent;
    }

    .kpi-label {
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      font-weight: 800;
      opacity: 0.82;
    }

    .kpi-value {
      font-size: clamp(24px, 2.6vw, 44px);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.05em;
    }

    .kpi-delta {
      font-size: 14px;
      font-weight: 800;
    }

    .delta-positive { color: var(--positive); }
    .delta-negative { color: var(--negative); }
    .kpi-card.hero .delta-positive,
    .kpi-card.hero .delta-negative { color: rgba(255,255,255,0.92); }

    .chart {
      width: 100%;
      min-height: 320px;
    }

    .chart.big {
      min-height: 430px;
    }

    .chart.map {
      min-height: 460px;
    }

    .summary-copy {
      display: grid;
      gap: 14px;
    }

    .summary-lede {
      font-size: 18px;
      font-weight: 800;
      line-height: 1.35;
    }

    .summary-copy p {
      margin: 0;
      color: var(--muted);
      line-height: 1.7;
      font-size: 14px;
    }

    .insight-list,
    .note-list {
      display: grid;
      gap: 12px;
    }

    .insight-card,
    .note-card {
      padding: 16px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.86);
    }

    .insight-card strong,
    .note-card strong {
      display: block;
      font-size: 14px;
      margin-bottom: 6px;
    }

    .insight-card p,
    .note-card p {
      margin: 0;
      color: var(--muted);
      line-height: 1.6;
      font-size: 13px;
    }

    .ranking-columns {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .ranking-list {
      display: grid;
      gap: 10px;
    }

    .ranking-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 12px;
      align-items: center;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255,255,255,0.84);
      border: 1px solid var(--line);
    }

    .ranking-item strong {
      display: block;
      font-size: 14px;
    }

    .ranking-item span {
      display: block;
      font-size: 12px;
      color: var(--muted);
      margin-top: 3px;
    }

    .ranking-item .value {
      font-weight: 800;
      font-size: 14px;
      text-align: right;
    }

    .banner {
      display: none;
      margin-top: 12px;
      padding: 12px 14px;
      border-radius: 16px;
      background: rgba(255, 122, 89, 0.10);
      border: 1px solid rgba(255, 122, 89, 0.18);
      color: #9b4a33;
      font-size: 13px;
      line-height: 1.55;
    }

    .banner.is-visible {
      display: block;
    }

    .footer-note {
      color: var(--muted);
      text-align: right;
      font-size: 12px;
      padding: 0 6px 4px;
    }

    @media (max-width: 1280px) {
      .selector-grid,
      .grid-four,
      .grid-three,
      .grid-two,
      .hero-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 760px) {
      body { padding: 10px; }
      .app-body { padding: 12px; }
      .window-bar { grid-template-columns: 1fr; }
      .hero-main, .hero-side, .selector-shell, .card-panel, .hero-kpis { padding: 16px; }
    }
  </style>
</head>
<body>
  <script id="payload-data" type="application/json">{{ payload_json | safe }}</script>
  <div class="app-window">
    <div class="window-bar">
      <div class="window-actions">
        <span class="window-pill accent"></span>
        <span class="window-pill alt"></span>
        <span class="window-pill"></span>
      </div>
      <div class="browser-strip">
        <div class="browser-tab">Bilan premium moderne</div>
        <div class="address-bar">
          <span>⌂</span>
          <div class="address-text" id="address-text"></div>
        </div>
      </div>
      <div class="window-meta">
        <span id="window-period"></span>
      </div>
    </div>

    <div class="app-body">
      <section class="hero-grid">
        <article class="panel hero-main">
          <div class="eyebrow">Windows-like navigator · premium moderne</div>
          <h1 id="hero-title"></h1>
          <p class="hero-copy" id="hero-copy"></p>
        </article>
        <aside class="panel hero-side" id="hero-side"></aside>
      </section>

      <div class="sticky-shell">
        <section class="panel selector-shell">
          <div class="selector-grid" id="selector-grid"></div>
          <div class="selector-footer">
            <div class="chip-row" id="active-filters"></div>
            <button class="button" type="button" id="reset-filters">Réinitialiser les filtres</button>
          </div>
        </section>

        <section class="panel nav-shell" id="primary-tabs"></section>
      </div>

      <main class="content-shell" id="content-root"></main>
      <div class="footer-note">HTML standalone. Les données métier et la géométrie cartographique sont embarquées. Les bibliothèques de visualisation sont chargées via CDN.</div>
    </div>
  </div>

  <datalist id="nace-options"></datalist>
  <datalist id="ape-options"></datalist>

  <script>
    const payload = JSON.parse(document.getElementById("payload-data").textContent);
    const managementFacts = payload.facts.management.rows.map((row) =>
      Object.fromEntries(payload.facts.management.columns.map((column, index) => [column, row[index]]))
    );
    const geoFacts = payload.facts.geography.rows.map((row) =>
      Object.fromEntries(payload.facts.geography.columns.map((column, index) => [column, row[index]]))
    );

    const state = {
      activeTab: payload.meta.default_tab,
      bilanSubtab: payload.meta.default_bilan_subtab,
      metric: payload.meta.default_metric,
      year: payload.meta.latest_year,
      periodMode: payload.meta.partial_latest_year ? "ytd" : "full",
      geoLevel: "region",
      category: payload.meta.filters.default_category,
      plan: payload.meta.filters.default_plan,
      codeCnrj: payload.meta.filters.default_code_cnrj,
      sector: payload.meta.filters.default_sector,
      nace: payload.meta.filters.default_nace,
      ape: payload.meta.filters.default_ape,
      includeOther: payload.meta.filters.default_include_other,
      contributionDimension: "sector",
      regionSource: "geographic"
    };

    const cache = new Map();
    const metricOrder = payload.meta.metric_tabs.map((item) => item.key);
    const naceOptions = payload.meta.filters.nace_options;
    const apeOptions = payload.meta.filters.ape_options;

    function initChrome() {
      document.getElementById("hero-title").textContent = payload.meta.title;
      document.getElementById("hero-copy").textContent =
        "Le shell reprend l’esprit des vues Excel tout en basculant sur une lecture applicative: bilan narratif, onglets métriques, treemap de contribution à l’évolution et sélecteurs globaux pilotés par les dimensions métier.";
      document.getElementById("address-text").textContent = payload.meta.source;
      updateWindowPeriod();
      renderHeroSide();
      populateDatalists();
      bindReset();
      renderSelectors();
      renderPrimaryTabs();
      renderApp();
    }

    function updateWindowPeriod() {
      document.getElementById("window-period").textContent =
        state.periodMode === "ytd"
          ? `Fenêtre active · ${state.year} à fin ${payload.meta.month_cutoff_label}`
          : `Fenêtre active · ${state.year} année complète`;
    }

    function renderHeroSide() {
      const side = document.getElementById("hero-side");
      const comparisonYear = getComparisonYear();
      side.innerHTML = "";
      [
        ["Source", payload.meta.source],
        ["Période max", `${payload.meta.latest_year} à fin ${payload.meta.month_cutoff_label}`],
        ["Comparaison", `${state.year} vs ${comparisonYear}`],
        ["Qualité carto", `${Math.round(payload.meta.geo_quality.department_coverage_ratio * 100)} % départements appariés`],
      ].forEach(([label, value]) => {
        const block = document.createElement("div");
        block.className = "meta-card";
        block.innerHTML = `<div class="meta-label">${label}</div><div class="meta-value">${value}</div>`;
        side.appendChild(block);
      });
    }

    function populateDatalists() {
      const naceList = document.getElementById("nace-options");
      naceList.innerHTML = "";
      naceOptions.forEach((item) => {
        const option = document.createElement("option");
        option.value = item.label;
        naceList.appendChild(option);
      });

      const apeList = document.getElementById("ape-options");
      apeList.innerHTML = "";
      apeOptions.forEach((item) => {
        const option = document.createElement("option");
        option.value = `${item.code} · ${item.label}`;
        apeList.appendChild(option);
      });
    }

    function bindReset() {
      document.getElementById("reset-filters").addEventListener("click", () => {
        state.year = payload.meta.latest_year;
        state.periodMode = payload.meta.partial_latest_year ? "ytd" : "full";
        state.geoLevel = "region";
        state.category = payload.meta.filters.default_category;
        state.plan = payload.meta.filters.default_plan;
        state.codeCnrj = payload.meta.filters.default_code_cnrj;
        state.sector = payload.meta.filters.default_sector;
        state.nace = payload.meta.filters.default_nace;
        state.ape = payload.meta.filters.default_ape;
        state.includeOther = payload.meta.filters.default_include_other;
        state.contributionDimension = "sector";
        state.regionSource = "geographic";
        renderApp();
      });
    }

    function renderSelectors() {
      const grid = document.getElementById("selector-grid");
      grid.innerHTML = "";
      addSelectField(grid, "Année", payload.meta.available_years, state.year, (value) => {
        state.year = Number(value);
        renderApp();
      });
      addSelectField(
        grid,
        "Période",
        payload.meta.filters.period_modes.map((item) => ({ value: item.key, label: item.label })),
        state.periodMode,
        (value) => {
          state.periodMode = value;
          renderApp();
        }
      );
      addSelectField(grid, "Niveau géographique", payload.meta.filters.geo_levels.map((item) => ({ value: item.key, label: item.label })), state.geoLevel, (value) => {
        state.geoLevel = value;
        renderApp();
      });
      addSelectField(grid, "Catégorie", [payload.meta.filters.default_category].concat(payload.meta.filters.categories), state.category, (value) => {
        state.category = value;
        renderApp();
      });
      addSelectField(grid, "Plan / DPA", [payload.meta.filters.default_plan].concat(payload.meta.filters.plans), state.plan, (value) => {
        state.plan = value;
        renderApp();
      });
      addSelectField(grid, "Code CNRJ", [payload.meta.filters.default_code_cnrj].concat(payload.meta.filters.code_cnrj), state.codeCnrj, (value) => {
        state.codeCnrj = value;
        renderApp();
      });
      addSelectField(grid, "Secteur", [payload.meta.filters.default_sector].concat(payload.meta.filters.sectors), state.sector, (value) => {
        state.sector = value;
        renderApp();
      });
      addInputField(grid, "Nace 88", state.nace === payload.meta.filters.default_nace ? "" : state.nace, "nace-options", (value) => {
        state.nace = value || payload.meta.filters.default_nace;
        renderApp();
      });
      addInputField(grid, "APE", state.ape, "ape-options", (value) => {
        state.ape = value;
        renderApp();
      });
      addCheckboxField(grid, "Inclure Autre non ciblé CNRJ", state.includeOther, (checked) => {
        state.includeOther = checked;
        renderApp();
      });
      renderActiveFilters();
    }

    function addSelectField(container, label, options, selected, onChange) {
      const field = document.createElement("div");
      field.className = "field";
      const labelNode = document.createElement("label");
      labelNode.textContent = label;
      const select = document.createElement("select");
      options.forEach((option) => {
        const node = document.createElement("option");
        if (typeof option === "object") {
          node.value = option.value;
          node.textContent = option.label;
        } else {
          node.value = option;
          node.textContent = option;
        }
        node.selected = String(node.value) === String(selected);
        select.appendChild(node);
      });
      select.addEventListener("change", (event) => onChange(event.target.value));
      field.appendChild(labelNode);
      field.appendChild(select);
      container.appendChild(field);
    }

    function addInputField(container, label, value, listId, onChange) {
      const field = document.createElement("div");
      field.className = "field";
      const labelNode = document.createElement("label");
      labelNode.textContent = label;
      const input = document.createElement("input");
      input.type = "text";
      input.value = value;
      input.setAttribute("list", listId);
      input.placeholder = label === "APE" ? "Rechercher un code ou libellé" : "Rechercher un libellé";
      input.addEventListener("change", (event) => onChange(event.target.value.trim()));
      field.appendChild(labelNode);
      field.appendChild(input);
      container.appendChild(field);
    }

    function addCheckboxField(container, label, checked, onChange) {
      const field = document.createElement("div");
      field.className = "field checkbox";
      const labelNode = document.createElement("label");
      labelNode.textContent = label;
      const input = document.createElement("input");
      input.type = "checkbox";
      input.checked = checked;
      input.addEventListener("change", () => onChange(input.checked));
      field.appendChild(labelNode);
      field.appendChild(input);
      container.appendChild(field);
    }

