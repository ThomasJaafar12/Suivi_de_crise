    function buildScopeLabel() {
      return `${state.year} · ${state.periodMode === "ytd" ? `à fin ${payload.meta.month_cutoff_label}` : "année complète"} · ${state.sector}`;
    }

    function getActiveMetric() {
      return state.activeTab === "bilan" ? state.metric : state.activeTab;
    }

    function contributionLabel() {
      const base = payload.meta.contribution_dimensions.find((item) => item.key === state.contributionDimension)?.label || "Secteur";
      if (state.contributionDimension !== "region") {
        return base;
      }
      const source = payload.meta.region_sources.find((item) => item.key === state.regionSource)?.label || "Région";
      return `${base} · ${source}`;
    }

    function getComparisonYear() {
      const previous = payload.meta.available_years.filter((year) => year < state.year).slice(-1)[0];
      return previous ?? state.year;
    }

    function getPeriodLimit(year) {
      if (state.periodMode === "ytd") {
        return payload.meta.month_cutoff;
      }
      if (year === payload.meta.latest_year && payload.meta.partial_latest_year) {
        return payload.meta.latest_month;
      }
      return 12;
    }

    function makeCacheKey(prefix, extra) {
      return [
        prefix,
        state.year,
        state.periodMode,
        state.category,
        state.plan,
        state.codeCnrj,
        state.sector,
        state.nace,
        state.ape,
        state.includeOther,
        state.geoLevel,
        extra || ""
      ].join("|");
    }

    function getFilteredManagementFacts(years = null) {
      const cacheKey = makeCacheKey("management", JSON.stringify(years || []));
      if (cache.has(cacheKey)) return cache.get(cacheKey);
      const periodYears = years || payload.meta.available_years;
      const data = managementFacts.filter((row) => {
        if (!periodYears.includes(row.y)) return false;
        if (row.m > getPeriodLimit(row.y)) return false;
        if (state.category !== payload.meta.filters.default_category && row.cat !== state.category) return false;
        if (state.plan !== payload.meta.filters.default_plan && row.plan !== state.plan) return false;
        if (state.codeCnrj !== payload.meta.filters.default_code_cnrj && row.cnrj !== state.codeCnrj) return false;
        if (state.sector !== payload.meta.filters.default_sector && row.sect !== state.sector) return false;
        if (state.nace !== payload.meta.filters.default_nace && row.n88l !== state.nace) return false;
        if (state.ape && `${row.ape} · ${row.apel}` !== state.ape) return false;
        if (!state.includeOther && row.sect === "Autre non ciblé CNRJ") return false;
        return true;
      });
      cache.set(cacheKey, data);
      return data;
    }

    function getFilteredGeoFacts(years = null) {
      const cacheKey = makeCacheKey("geo", JSON.stringify(years || []));
      if (cache.has(cacheKey)) return cache.get(cacheKey);
      const periodYears = years || payload.meta.available_years;
      const data = geoFacts.filter((row) => {
        if (!periodYears.includes(row.y)) return false;
        if (row.m > getPeriodLimit(row.y)) return false;
        if (state.category !== payload.meta.filters.default_category && row.cat !== state.category) return false;
        if (state.plan !== payload.meta.filters.default_plan && row.plan !== state.plan) return false;
        if (state.codeCnrj !== payload.meta.filters.default_code_cnrj && row.cnrj !== state.codeCnrj) return false;
        if (state.sector !== payload.meta.filters.default_sector && row.sect !== state.sector) return false;
        if (state.nace !== payload.meta.filters.default_nace && row.n88l !== state.nace) return false;
        if (!state.includeOther && row.sect === "Autre non ciblé CNRJ") return false;
        return true;
      });
      cache.set(cacheKey, data);
      return data;
    }

    function summarizeFacts(records) {
      return records.reduce((acc, row) => {
        acc.nb += Number(row.nb || 0);
        acc.amount += Number(row.amt || 0);
        acc.durationTotal += Number(row.dur || 0);
        return acc;
      }, { nb: 0, amount: 0, durationTotal: 0 });
    }

    function metricFromBucket(bucket, metric) {
      if (metric === "nb") return bucket.nb;
      if (metric === "amount") return bucket.amount;
      if (metric === "avg_duration") return bucket.nb ? bucket.durationTotal / bucket.nb : 0;
      if (metric === "avg_ticket") return bucket.nb ? bucket.amount / bucket.nb : 0;
      return 0;
    }

    function buildKpiMetrics() {
      const currentYear = state.year;
      const comparisonYear = getComparisonYear();
      const current = summarizeFacts(getFilteredManagementFacts([currentYear]));
      const previous = summarizeFacts(getFilteredManagementFacts([comparisonYear]));
      const cards = [
        {
          key: "nb",
          label: payload.meta.metric_labels.nb,
          value: metricFromBucket(current, "nb"),
          delta: percentDelta(metricFromBucket(current, "nb"), metricFromBucket(previous, "nb"))
        },
        {
          key: "amount",
          label: payload.meta.metric_labels.amount,
          value: metricFromBucket(current, "amount"),
          delta: percentDelta(metricFromBucket(current, "amount"), metricFromBucket(previous, "amount"))
        },
        {
          key: "avg_duration",
          label: payload.meta.metric_labels.avg_duration,
          value: metricFromBucket(current, "avg_duration"),
          delta: percentDelta(metricFromBucket(current, "avg_duration"), metricFromBucket(previous, "avg_duration"))
        },
        {
          key: "avg_ticket",
          label: payload.meta.metric_labels.avg_ticket,
          value: metricFromBucket(current, "avg_ticket"),
          delta: percentDelta(metricFromBucket(current, "avg_ticket"), metricFromBucket(previous, "avg_ticket"))
        }
      ];
      return {
        cards,
        comparisonYear,
        current,
        previous
      };
    }

    function percentDelta(current, previous) {
      if (!previous) return 0;
      return ((current / previous) - 1) * 100;
    }

    function renderKpiGrid(targetId, metrics, heroMetric) {
      const target = document.getElementById(targetId);
      target.innerHTML = "";
      metrics.cards.forEach((card) => {
        const node = document.createElement("article");
        node.className = `kpi-card${card.key === heroMetric ? " hero" : ""}`;
        const deltaClass = card.delta >= 0 ? "delta-positive" : "delta-negative";
        node.innerHTML = `
          <div class="kpi-label">${card.label}</div>
          <div class="kpi-value">${formatMetric(card.key, card.value)}</div>
          <div class="kpi-delta ${deltaClass}">${formatDelta(card.delta)} vs ${metrics.comparisonYear}</div>
        `;
        target.appendChild(node);
      });
    }

    function renderOverviewSummary(targetId, metrics) {
      const target = document.getElementById(targetId);
      const currentMetric = getActiveMetric();
      const contributionRows = buildContributionRows(currentMetric, state.contributionDimension, state.regionSource);
      const topPositive = contributionRows.filter((row) => row.delta > 0).sort((a, b) => b.delta - a.delta)[0];
      const topNegative = contributionRows.filter((row) => row.delta < 0).sort((a, b) => a.delta - b.delta)[0];
      target.innerHTML = `
        <div class="summary-lede">
          ${payload.meta.metric_labels[currentMetric]} : ${formatMetric(currentMetric, metrics.cards.find((item) => item.key === currentMetric).value)}
          sur ${buildScopeLabel()}.
        </div>
        <p>${state.periodMode === "ytd" ? `La lecture YTD est arrêtée à fin ${payload.meta.month_cutoff_label}.` : "La lecture porte sur l’année disponible complète."} Le bilan conserve les filtres Excel clés tout en hiérarchisant la contribution des ventilations à l’évolution.</p>
        <div class="insight-list">
          <div class="insight-card">
            <strong>Contributeur positif principal</strong>
            <p>${topPositive ? `${topPositive.name} avec ${formatMetric(currentMetric, topPositive.delta)} (${topPositive.contribution.toFixed(1).replace(".", ",")} % de la variation).` : "Aucun contributeur positif sur la fenêtre courante."}</p>
          </div>
          <div class="insight-card">
            <strong>Contributeur négatif principal</strong>
            <p>${topNegative ? `${topNegative.name} avec ${formatMetric(currentMetric, topNegative.delta)} (${topNegative.contribution.toFixed(1).replace(".", ",")} % de la variation).` : "Aucun contributeur négatif sur la fenêtre courante."}</p>
          </div>
        </div>
      `;
    }

    function renderTimeseries(targetId, metricKey) {
      const facts = getFilteredManagementFacts(payload.meta.available_years);
      const traces = payload.meta.available_years.map((year) => {
        const buckets = new Map();
        facts.forEach((row) => {
          if (row.y !== year) return;
          const existing = buckets.get(row.m) || { nb: 0, amount: 0, durationTotal: 0 };
          existing.nb += Number(row.nb || 0);
          existing.amount += Number(row.amt || 0);
          existing.durationTotal += Number(row.dur || 0);
          buckets.set(row.m, existing);
        });
        const limit = getPeriodLimit(year);
        const months = Array.from({ length: limit }, (_, index) => index + 1);
        return {
          type: "scatter",
          mode: year === state.year ? "lines+markers" : "lines",
          name: String(year),
          x: months.map((month) => monthLabel(month)),
          y: months.map((month) => metricFromBucket(buckets.get(month) || { nb: 0, amount: 0, durationTotal: 0 }, metricKey)),
          line: {
            width: year === state.year ? 4 : 2.5,
            shape: year === state.year ? "spline" : "linear"
          },
          fill: year === state.year ? "tozeroy" : undefined
        };
      });
      Plotly.react(targetId, traces, plotlyLayout(metricKey), plotlyConfig());
    }

    function renderCurrentDistributionTreemap(targetId, metricKey) {
      const currentFacts = getFilteredManagementFacts([state.year]);
      const grouped = groupByDimension(currentFacts, "sect", metricKey);
      const rows = Array.from(grouped.entries())
        .map(([name, bucket]) => ({ name, value: metricFromBucket(bucket, metricKey) }))
        .sort((a, b) => b.value - a.value);
      Plotly.react(targetId, [{
        type: "treemap",
        labels: rows.map((row) => row.name),
        parents: rows.map(() => ""),
        values: rows.map((row) => Math.max(row.value, 0)),
        texttemplate: "<b>%{label}</b><br>%{value:,.2f}",
        marker: { colorscale: [["0", "#d9ecf0"], ["0.5", "#7ab2bf"], ["1", "#102a43"]] },
        hovertemplate: "%{label}<br>" + payload.meta.metric_labels[metricKey] + ": %{value}<extra></extra>",
      }], {
        margin: { l: 0, r: 0, t: 0, b: 0 },
        paper_bgcolor: "rgba(0,0,0,0)"
      }, plotlyConfig());
    }

    function buildContributionRows(metricKey, dimension, regionSource) {
      const currentYear = state.year;
      const comparisonYear = getComparisonYear();
      const useGeo = dimension === "region" && regionSource === "geographic";
      const facts = useGeo
        ? getFilteredGeoFacts([currentYear, comparisonYear])
        : getFilteredManagementFacts([currentYear, comparisonYear]);
      const field = dimension === "sector" ? "sect" : dimension === "nace" ? "n88l" : (regionSource === "geographic" ? "rgg" : "rgm");
      const currentBuckets = groupByDimension(facts.filter((row) => row.y === currentYear), field, metricKey);
      const previousBuckets = groupByDimension(facts.filter((row) => row.y === comparisonYear), field, metricKey);
      const keys = new Set([...currentBuckets.keys(), ...previousBuckets.keys()]);
      const rows = Array.from(keys).map((name) => {
        const current = currentBuckets.get(name) || { nb: 0, amount: 0, durationTotal: 0 };
        const previous = previousBuckets.get(name) || { nb: 0, amount: 0, durationTotal: 0 };
        const currentValue = metricFromBucket(current, metricKey);
        const previousValue = metricFromBucket(previous, metricKey);
        return {
          name,
          current: currentValue,
          previous: previousValue,
          delta: currentValue - previousValue,
        };
      });
      const totalDelta = rows.reduce((sum, row) => sum + row.delta, 0);
      return rows
        .map((row) => ({
          ...row,
          contribution: totalDelta ? (row.delta / totalDelta) * 100 : 0,
          absDelta: Math.abs(row.delta),
          sign: row.delta >= 0 ? "positive" : "negative"
        }))
        .filter((row) => row.absDelta > 0)
        .sort((a, b) => b.absDelta - a.absDelta);
    }

    function renderContributionTreemap(targetId, metricKey, compactMode) {
      const rows = buildContributionRows(metricKey, state.contributionDimension, state.regionSource);
      const sourceLabel = contributionLabel();
      Plotly.react(targetId, [{
        type: "treemap",
        labels: rows.map((row) => row.name),
        parents: rows.map(() => ""),
        values: rows.map((row) => row.absDelta),
        texttemplate: compactMode ? "<b>%{label}</b><br>%{value:,.0f}" : "<b>%{label}</b><br>%{customdata[0]}<br>%{customdata[1]} %",
        marker: {
          colors: rows.map((row) => row.delta >= 0 ? "#1f7a8c" : "#ff7a59"),
          line: { width: 1, color: "rgba(255,255,255,0.85)" }
        },
        hovertemplate:
          "%{label}<br>" +
          "Courant: %{customdata[2]}<br>" +
          "N-1: %{customdata[3]}<br>" +
          "Delta: %{customdata[0]}<br>" +
          "Contribution: %{customdata[1]} %<extra>" + sourceLabel + "</extra>",
        customdata: rows.map((row) => [
          formatMetric(metricKey, row.delta),
          row.contribution.toFixed(1).replace(".", ","),
          formatMetric(metricKey, row.current),
          formatMetric(metricKey, row.previous)
        ])
      }], {
        margin: { l: 0, r: 0, t: 0, b: 0 },
        paper_bgcolor: "rgba(0,0,0,0)"
      }, plotlyConfig());
    }

    function renderContributionRankings(rows) {
      renderRankingList(
        "positive-contributors",
        rows.filter((row) => row.delta > 0).sort((a, b) => b.delta - a.delta).slice(0, 6),
        getActiveMetric(),
        false
      );
      renderRankingList(
        "negative-contributors",
        rows.filter((row) => row.delta < 0).sort((a, b) => a.delta - b.delta).slice(0, 6),
        getActiveMetric(),
        true
      );
    }

    function renderMap(targetId, metricKey, bannerId) {
      const container = document.getElementById(targetId);
      const chart = echarts.getInstanceByDom(container) || echarts.init(container, null, { renderer: "canvas" });
      const geoJson = payload.geojson.departments_display;
      const facts = getFilteredGeoFacts([state.year]);
      const grouped = state.geoLevel === "region"
        ? groupByDimension(facts, "rgg", metricKey)
        : groupByDimension(facts, "dpt", metricKey);

      echarts.registerMap("crise_departments_premium", geoJson);
      const mapData = geoJson.features.map((feature) => {
        const label = state.geoLevel === "region" ? feature.properties.excel_region : feature.properties.excel_department;
        const bucket = label ? grouped.get(label) : null;
        return {
          name: feature.properties.name || feature.properties.nom,
          value: bucket ? metricFromBucket(bucket, metricKey) : null,
          labelValue: label || feature.properties.nom
        };
      });
      const values = mapData.map((item) => item.value).filter((value) => value !== null);
      const max = values.length ? Math.max(...values) : 1;

      chart.setOption({
        backgroundColor: "transparent",
        tooltip: {
          trigger: "item",
          formatter: (params) => {
            const value = params.value == null ? "N/A" : formatMetric(metricKey, params.value);
            return `${params.data.labelValue}<br>${payload.meta.metric_labels[metricKey]}: ${value}`;
          }
        },
        visualMap: {
          min: 0,
          max,
          left: 10,
          bottom: 10,
          text: ["Fort", "Faible"],
          calculable: true,
          inRange: {
            color: ["#d7ecf2", "#8cbfcc", "#1f7a8c", "#102a43"]
          },
          textStyle: { color: "#62728a" }
        },
        series: [{
          type: "map",
          map: "crise_departments_premium",
          roam: true,
          layoutCenter: ["52%", "50%"],
          layoutSize: "96%",
          emphasis: { label: { show: false } },
          itemStyle: {
            borderColor: "rgba(255,255,255,0.85)",
            borderWidth: 0.8
          },
          data: mapData
        }]
      });

      const banner = document.getElementById(bannerId);
      if (!banner) return;
      if (state.ape) {
        banner.className = "banner is-visible";
        banner.textContent = "Le filtre APE n’est pas disponible sur la source géographique. La carte et le ranking ignorent donc cette sélection.";
      } else {
        banner.className = "banner";
        banner.textContent = "";
      }
    }

    function renderGeographicRanking(targetId, metricKey) {
      const facts = getFilteredGeoFacts([state.year]);
      const field = state.geoLevel === "region" ? "rgg" : "dpt";
      const grouped = groupByDimension(facts, field, metricKey);
      const rows = Array.from(grouped.entries())
        .map(([name, bucket]) => ({
          name,
          value: metricFromBucket(bucket, metricKey),
          nb: bucket.nb,
          avgDuration: bucket.nb ? bucket.durationTotal / bucket.nb : 0
        }))
        .filter((row) => !["ETRANGER", "TOM", "NON_IDENTIFIABLE", "Etranger", "Tom"].includes(row.name))
        .sort((a, b) => b.value - a.value)
        .slice(0, state.geoLevel === "region" ? 12 : 15);
      renderRankingList(targetId, rows, metricKey, false);
    }

    function renderRankingList(targetId, rows, metricKey, invertDelta) {
      const target = document.getElementById(targetId);
      target.innerHTML = "";
      rows.forEach((row, index) => {
        const item = document.createElement("div");
        item.className = "ranking-item";
        const extra = row.contribution !== undefined
          ? `${row.contribution.toFixed(1).replace(".", ",")} % de contribution`
          : `${formatMetric("nb", row.nb || 0)} · durée moy. ${formatMetric("avg_duration", row.avgDuration || 0)}`;
        const value = row.delta !== undefined ? formatMetric(metricKey, row.delta) : formatMetric(metricKey, row.value);
        item.innerHTML = `
          <div>
            <strong>${index + 1}. ${row.name}</strong>
            <span>${extra}</span>
          </div>
          <div class="value">${value}</div>
        `;
        target.appendChild(item);
      });
    }

    function groupByDimension(records, field, metricKey) {
      const grouped = new Map();
      records.forEach((row) => {
        const key = row[field];
        if (!key) return;
        const bucket = grouped.get(key) || { nb: 0, amount: 0, durationTotal: 0 };
        bucket.nb += Number(row.nb || 0);
        bucket.amount += Number(row.amt || 0);
        bucket.durationTotal += Number(row.dur || 0);
        grouped.set(key, bucket);
      });
      return grouped;
    }

    function formatMetric(metric, value) {
      if (metric === "nb") {
        return new Intl.NumberFormat("fr-FR", { maximumFractionDigits: 0 }).format(value);
      }
      if (metric === "amount") {
        if (Math.abs(value) >= 1_000_000_000) return `${(value / 1_000_000_000).toFixed(2).replace(".", ",")} Md€`;
        if (Math.abs(value) >= 1_000_000) return `${(value / 1_000_000).toFixed(1).replace(".", ",")} M€`;
        if (Math.abs(value) >= 1_000) return `${(value / 1_000).toFixed(0).replace(".", ",")} k€`;
        return `${new Intl.NumberFormat("fr-FR", { maximumFractionDigits: 0 }).format(value)} €`;
      }
      if (metric === "avg_duration") {
        return `${Number(value).toFixed(1).replace(".", ",")} mois`;
      }
      if (metric === "avg_ticket") {
        return `${new Intl.NumberFormat("fr-FR", { maximumFractionDigits: 0 }).format(value)} €`;
      }
      return String(value);
    }

    function formatDelta(value) {
      const sign = value >= 0 ? "+" : "";
      return `${sign}${value.toFixed(1).replace(".", ",")} %`;
    }

    function monthLabel(month) {
      const labels = {
        1: "Jan", 2: "Fév", 3: "Mar", 4: "Avr", 5: "Mai", 6: "Juin",
        7: "Juil", 8: "Août", 9: "Sep", 10: "Oct", 11: "Nov", 12: "Déc"
      };
      return labels[month];
    }

    function plotlyLayout(metricKey) {
      return {
        margin: { l: 50, r: 16, t: 10, b: 36 },
        paper_bgcolor: "rgba(0,0,0,0)",
        plot_bgcolor: "rgba(0,0,0,0)",
        legend: { orientation: "h", y: 1.12 },
        xaxis: {
          showgrid: false,
          tickfont: { size: 11, color: "#62728a" }
        },
        yaxis: {
          title: payload.meta.metric_labels[metricKey],
          zeroline: false,
          gridcolor: "rgba(98,114,138,0.12)"
        }
      };
    }

    function plotlyConfig() {
      return {
        displayModeBar: false,
        responsive: true
      };
    }

    initChrome();
    window.addEventListener("resize", () => {
      ["metric-map", "bilan-map"].forEach((id) => {
        const node = document.getElementById(id);
        if (!node) return;
        const instance = echarts.getInstanceByDom(node);
        if (instance) instance.resize();
      });
    });
  </script>
</body>
</html>
